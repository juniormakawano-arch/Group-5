<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily Health Goals"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Step Goal:" />

    <EditText
        android:id="@+id/etStepGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 10000"
        android:inputType="number"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Water Goal (ml):" />

    <EditText
        android:id="@+id/etWaterGoal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 3000"
        android:inputType="number"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnSaveGoals"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="SAVE GOALS"
        android:backgroundTint="#4CAF50"
        android:textColor="@android:color/white" />
</LinearLayout>