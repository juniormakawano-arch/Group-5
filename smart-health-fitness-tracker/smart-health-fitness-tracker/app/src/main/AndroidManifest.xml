<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="Smart Health Tracker"
        android:theme="@style/Theme.HealthFit"
        android:icon="@android:drawable/ic_menu_report_image">

        <!-- 1. Login Screen (Launcher) -->
        <activity android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 2. Dashboard -->
        <activity android:name=".DashboardActivity"
            android:exported="false" />

        <!-- 3. Log Activity -->
        <activity android:name=".LogActivity"
            android:exported="false" />

        <!-- 4. Member 4 Activities (ONLY DEFINE THESE ONCE) -->
        <activity
            android:name=".WorkoutListActivity"
            android:label="Workout Library"
            android:exported="false" />

        <activity
            android:name=".GoalSettingsActivity"
            android:label="Set Daily Goals"
            android:exported="false" />

    </application>
</manifest>